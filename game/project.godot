; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Critter Quitters Pest Control"
run/main_scene="res://ui/StartScreen.tscn"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://assets/icon.svg"

[autoload]

GameState="*res://core/GameState.gd"

[dotnet]

project/assembly_name="Critter Quitters Pest Control"

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="gl_compatibility"
