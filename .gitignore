# Godot 4 .gitignore

# Godot-specific ignores
.godot/
*.translation

# Imported assets (generated by Godot)
*.import

# OS-specific
.DS_Store
Thumbs.db

# Build output — produced by export pipeline, never committed
dist/

# Android signing key — secret, never commit; decode from ANDROID_KEYSTORE_BASE64 secret in CI
build/android_release.keystore
